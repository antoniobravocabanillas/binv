generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  TECHNICIAN
  SALES
  EDITOR
  ADMIN
  SUPER_ADMIN
  COMMERCIAL_ADMIN
  SURVEYOR
  ENGINEER
  ARCHITECT
  SUPPORT
}

enum OrderStatus {
  PENDING
  QUOTED
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  EVALUATION
  QUOTED
  NEGOTIATION
  WON
  LOST
  REQUIRES_TECH_SUPPORT
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CommissionType {
  SALE_PERCENTAGE
  MARGIN_PERCENTAGE
  FIXED_AMOUNT
  CATEGORY_PERCENTAGE
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  FINISHED
  PUBLISHED
  ARCHIVED
}

enum ProjectRole {
  SURVEYOR
  ENGINEER
  ARCHITECT
  SELLER
  SUPPORT
  MANAGER
}

enum ChatStatus {
  WAITING
  ACTIVE
  CLOSED
}

enum StaffDepartment {
  SALES
  TECHNICAL_SUPPORT
  FIELD_ENGINEERING
  RENTAL_SERVICE
  ADMINISTRATION
}

model User {
  id            String             @id @default(cuid())
  name          String?
  email         String             @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role               @default(CUSTOMER)
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  addresses     Address[]
  favorites     Favorite[]
  assignedChats ChatConversation[]
  staffProfile  StaffProfile?
  clientProfile Client?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Client {
  id          String    @id @default(cuid())
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  company     String?
  document    String?
  email       String    @unique
  phone       String?
  address     String?
  contactName String?
  status      String    @default("prospecto")
  leads       Lead[]
  quotes      Quote[]
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  sku            String           @unique
  brand          String
  model          String?
  summary        String
  description    String
  price          Decimal?
  stock          Int              @default(0)
  currency       String           @default("USD")
  requiresQuote  Boolean          @default(false)
  availability   String
  badge          String?
  images         String[]
  mainImage      String?
  manualUrl      String?
  rentalPrice    Decimal?
  commercialMode String           @default("venta")
  location       String?
  tags           String[]
  isFeatured     Boolean          @default(false)
  isVisible      Boolean          @default(true)
  technicalSheet String?
  specifications Json
  isActive       Boolean          @default(true)
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  orderItems     OrderItem[]
  quoteItems     QuoteItem[]
  favorites      Favorite[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([categoryId])
  @@index([brand])
  @@index([requiresQuote])
  @@index([stock])
  @@index([isActive])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  sku       String   @unique
  price     Decimal?
  stock     Int      @default(0)
  options   Json
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  customerName  String
  customerEmail String
  customerPhone String?
  status        OrderStatus @default(PENDING)
  total         Decimal
  currency      String      @default("USD")
  notes         String?
  items         OrderItem[]
  addressId     String?
  address       Address?    @relation(fields: [addressId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status, createdAt])
  @@index([customerEmail])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal
  subtotal  Decimal
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Address {
  id         String  @id @default(cuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  label      String?
  line1      String
  line2      String?
  city       String
  region     String?
  country    String  @default("PE")
  postalCode String?
  orders     Order[]
}

model Favorite {
  id        String  @id @default(cuid())
  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  content     Json
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
}

model CmsPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  metaTitle   String?
  metaDesc    String?
  content     Json
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  ctaLabel  String?
  ctaHref   String?
  image     String?
  placement String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  author    String
  company   String?
  role      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  position  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, position])
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     Json
  author      String?
  category    String?
  metaTitle   String?
  metaDesc    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
  @@index([category])
}

model Lead {
  id                String        @id @default(cuid())
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignedProfileId String?
  assignedProfile   StaffProfile? @relation("LeadAssignedProfile", fields: [assignedProfileId], references: [id], onDelete: SetNull)
  name              String
  email             String
  phone             String?
  company           String?
  message           String
  source            String?
  interest          String?
  priority          LeadPriority  @default(MEDIUM)
  estimatedValue    Decimal?
  nextFollowUpAt    DateTime?
  status            LeadStatus    @default(NEW)
  notes             LeadNote[]
  quotes            Quote[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([assignedProfileId])
  @@index([clientId])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String?
  body      String
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model Quote {
  id              String        @id @default(cuid())
  number          String        @unique
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId          String?
  lead            Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  sellerProfileId String?
  sellerProfile   StaffProfile? @relation("QuoteSellerProfile", fields: [sellerProfileId], references: [id], onDelete: SetNull)
  customerName    String
  customerEmail   String?
  company         String?
  status          QuoteStatus   @default(DRAFT)
  currency        String        @default("USD")
  subtotal        Decimal       @default(0)
  discount        Decimal       @default(0)
  tax             Decimal       @default(0)
  total           Decimal       @default(0)
  validUntil      DateTime?
  terms           String?
  deliveryTime    String?
  observations    String?
  items           QuoteItem[]
  commissions     Commission[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([sellerProfileId])
  @@index([clientId])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  type        String   @default("product")
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0)
  discount    Decimal  @default(0)
  subtotal    Decimal  @default(0)

  @@index([quoteId])
  @@index([productId])
}

model Commission {
  id              String           @id @default(cuid())
  quoteId         String?
  quote           Quote?           @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  sellerProfileId String
  sellerProfile   StaffProfile     @relation("CommissionSellerProfile", fields: [sellerProfileId], references: [id], onDelete: Cascade)
  type            CommissionType   @default(SALE_PERCENTAGE)
  baseAmount      Decimal          @default(0)
  rate            Decimal          @default(0)
  amount          Decimal          @default(0)
  status          CommissionStatus @default(PENDING)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([sellerProfileId, status])
  @@index([quoteId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  message   String
  intent    String?
  context   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model ChatConversation {
  id                String        @id @default(cuid())
  customerName      String
  customerEmail     String?
  customerPhone     String?
  topic             String?
  status            ChatStatus    @default(WAITING)
  assignedToId      String?
  assignedTo        User?         @relation(fields: [assignedToId], references: [id])
  assignedProfileId String?
  assignedProfile   StaffProfile? @relation(fields: [assignedProfileId], references: [id], onDelete: SetNull)
  messages          ChatMessage[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([assignedToId])
  @@index([assignedProfileId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String
  body           String
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

model StaffProfile {
  id              String             @id @default(cuid())
  userId          String?            @unique
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName     String
  email           String?            @unique
  phone           String?
  roleTitle       String
  department      StaffDepartment    @default(SALES)
  avatar          String?
  commissionType  CommissionType     @default(SALE_PERCENTAGE)
  commissionRate  Decimal            @default(5)
  fixedCommission Decimal            @default(0)
  monthlyGoal     Decimal            @default(0)
  territory       String?
  internalNotes   String?
  specialties     String[]
  tools           Json
  active          Boolean            @default(true)
  assignedChats   ChatConversation[]
  assignedLeads   Lead[]             @relation("LeadAssignedProfile")
  quotes          Quote[]            @relation("QuoteSellerProfile")
  commissions     Commission[]       @relation("CommissionSellerProfile")
  projectMembers  ProjectMember[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([department, active])
}

model Project {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientName      String?
  location        String?
  category        String?
  servicesApplied String[]
  summary         String
  description     String
  challenge       String?
  solution        String?
  results         String?
  status          ProjectStatus   @default(PLANNING)
  isPublic        Boolean         @default(false)
  isFeatured      Boolean         @default(false)
  images          ProjectImage[]
  members         ProjectMember[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, isPublic])
  @@index([isFeatured])
  @@index([clientId])
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([projectId, position])
}

model ProjectMember {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  role           ProjectRole  @default(SURVEYOR)
  createdAt      DateTime     @default(now())

  @@unique([projectId, staffProfileId, role])
  @@index([staffProfileId])
}
