generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  TECHNICIAN
  SALES
  EDITOR
  ADMIN
  SUPER_ADMIN
  COMMERCIAL_ADMIN
  SURVEYOR
  ENGINEER
  ARCHITECT
  SUPPORT
}

enum OrderStatus {
  PENDING
  QUOTED
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  EVALUATION
  QUOTED
  NEGOTIATION
  WON
  LOST
  REQUIRES_TECH_SUPPORT
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OpportunityStatus {
  OPEN
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  ARCHIVED
}

enum SaleStatus {
  PENDING
  CONFIRMED
  INVOICED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum CommissionType {
  SALE_PERCENTAGE
  MARGIN_PERCENTAGE
  FIXED_AMOUNT
  CATEGORY_PERCENTAGE
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  FINISHED
  PUBLISHED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum ProjectRole {
  SURVEYOR
  ENGINEER
  ARCHITECT
  SELLER
  SUPPORT
  MANAGER
}

enum TechnicalAvailability {
  AVAILABLE
  FIELD
  BUSY
  OFFLINE
}

enum TicketCategory {
  EQUIPMENT
  SERVICE
  CALIBRATION
  REPAIR
  WARRANTY
  TECHNICAL_QUERY
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  REVIEWING
  WAITING_CUSTOMER
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum BotProvider {
  LOCAL
  OPENROUTER
  GEMINI
  GROQ
  HUGGINGFACE
  OLLAMA
}

enum BotQuestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  LEAD
  QUOTE
  TICKET
  CHAT
  PROJECT
  COMMISSION
  FAQ
  SYSTEM
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  CONVERTED
  ASSIGNED
  COMMENTED
  UPLOADED
  APPROVED
  REJECTED
}

enum ChatStatus {
  WAITING
  ACTIVE
  CLOSED
}

enum StaffDepartment {
  SALES
  TECHNICAL_SUPPORT
  FIELD_ENGINEERING
  RENTAL_SERVICE
  ADMINISTRATION
}

model User {
  id               String                @id @default(cuid())
  name             String?
  email            String                @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  role             Role                  @default(CUSTOMER)
  accounts         Account[]
  sessions         Session[]
  orders           Order[]
  addresses        Address[]
  favorites        Favorite[]
  assignedChats    ChatConversation[]
  ticketMessages   TicketMessage[]
  internalMessages InternalChatMessage[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  staffProfile     StaffProfile?
  clientProfile    Client?
  clientAccounts   ClientAccount[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model Company {
  id            String          @id @default(cuid())
  legalName     String
  tradeName     String?
  document      String?
  email         String?
  phone         String?
  address       String?
  city          String?
  industry      String?
  status        String          @default("prospecto")
  contacts      Contact[]
  accounts      ClientAccount[]
  clients       Client[]
  leads         Lead[]
  opportunities Opportunity[]
  quotes        Quote[]
  sales         Sale[]
  projects      Project[]
  tickets       Ticket[]
  documents     Document[]
  activities    ActivityLog[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([document])
  @@index([status])
  @@index([deletedAt])
}

model Contact {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  roleTitle      String?
  email          String?
  phone          String?
  whatsapp       String?
  isPrimary      Boolean         @default(false)
  clientAccounts ClientAccount[]
  leads          Lead[]
  opportunities  Opportunity[]
  quotes         Quote[]
  sales          Sale[]
  tickets        Ticket[]
  documents      Document[]
  activities     ActivityLog[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@unique([companyId, email])
  @@index([email])
  @@index([deletedAt])
}

model ClientAccount {
  id          String    @id @default(cuid())
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  clientId    String?   @unique
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  status      String    @default("invited")
  invitedAt   DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([companyId])
  @@index([contactId])
  @@index([status])
}

model Client {
  id          String           @id @default(cuid())
  userId      String?          @unique
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId   String?
  companyRef  Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  account     ClientAccount?
  name        String
  company     String?
  document    String?
  email       String           @unique
  phone       String?
  address     String?
  contactName String?
  status      String           @default("prospecto")
  leads       Lead[]
  quotes      Quote[]
  projects    Project[]
  tickets     Ticket[]
  documents   ClientDocument[]
  sales       Sale[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  @@index([email])
  @@index([status])
  @@index([companyId])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  sku            String           @unique
  brand          String
  model          String?
  summary        String
  description    String
  price          Decimal?
  stock          Int              @default(0)
  currency       String           @default("USD")
  requiresQuote  Boolean          @default(false)
  availability   String
  badge          String?
  images         String[]
  mainImage      String?
  manualUrl      String?
  rentalPrice    Decimal?
  commercialMode String           @default("venta")
  location       String?
  tags           String[]
  isFeatured     Boolean          @default(false)
  isVisible      Boolean          @default(true)
  technicalSheet String?
  specifications Json
  isActive       Boolean          @default(true)
  categoryId     String
  category       Category         @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  orderItems     OrderItem[]
  quoteItems     QuoteItem[]
  favorites      Favorite[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([categoryId])
  @@index([brand])
  @@index([requiresQuote])
  @@index([stock])
  @@index([isActive])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  sku       String   @unique
  price     Decimal?
  stock     Int      @default(0)
  options   Json
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  customerName  String
  customerEmail String
  customerPhone String?
  status        OrderStatus @default(PENDING)
  total         Decimal
  currency      String      @default("USD")
  notes         String?
  items         OrderItem[]
  addressId     String?
  address       Address?    @relation(fields: [addressId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status, createdAt])
  @@index([customerEmail])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal
  subtotal  Decimal
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Address {
  id         String  @id @default(cuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  label      String?
  line1      String
  line2      String?
  city       String
  region     String?
  country    String  @default("PE")
  postalCode String?
  orders     Order[]
}

model Favorite {
  id        String  @id @default(cuid())
  userId    String
  productId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  content     Json
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
}

model CmsPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  metaTitle   String?
  metaDesc    String?
  content     Json
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  ctaLabel  String?
  ctaHref   String?
  image     String?
  placement String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  author    String
  company   String?
  role      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Faq {
  id         String   @id @default(cuid())
  question   String
  answer     String
  category   String?
  origin     String   @default("manual")
  approved   Boolean  @default(true)
  usageCount Int      @default(0)
  position   Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([active, approved, position])
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     Json
  author      String?
  category    String?
  metaTitle   String?
  metaDesc    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
  @@index([category])
}

model Lead {
  id                String        @id @default(cuid())
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  companyId         String?
  companyRef        Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId         String?
  contact           Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedProfileId String?
  assignedProfile   StaffProfile? @relation("LeadAssignedProfile", fields: [assignedProfileId], references: [id], onDelete: SetNull)
  name              String
  email             String
  phone             String?
  company           String?
  message           String
  source            String?
  interest          String?
  priority          LeadPriority  @default(MEDIUM)
  estimatedValue    Decimal?
  nextFollowUpAt    DateTime?
  status            LeadStatus    @default(NEW)
  notes             LeadNote[]
  quotes            Quote[]
  opportunity       Opportunity?
  activities        ActivityLog[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  @@index([status, createdAt])
  @@index([email])
  @@index([assignedProfileId])
  @@index([clientId])
  @@index([companyId])
  @@index([contactId])
  @@index([deletedAt])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String?
  body      String
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model Quote {
  id              String        @id @default(cuid())
  number          String        @unique
  clientId        String?
  client          Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  companyId       String?
  companyRef      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId   String?
  opportunity     Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  leadId          String?
  lead            Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  sellerProfileId String?
  sellerProfile   StaffProfile? @relation("QuoteSellerProfile", fields: [sellerProfileId], references: [id], onDelete: SetNull)
  publicToken     String?       @unique @default(cuid())
  customerName    String
  customerEmail   String?
  company         String?
  status          QuoteStatus   @default(DRAFT)
  currency        String        @default("USD")
  subtotal        Decimal       @default(0)
  discount        Decimal       @default(0)
  tax             Decimal       @default(0)
  total           Decimal       @default(0)
  validUntil      DateTime?
  terms           String?
  deliveryTime    String?
  observations    String?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  items           QuoteItem[]
  commissions     Commission[]
  sale            Sale?
  activities      ActivityLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([status, createdAt])
  @@index([sellerProfileId])
  @@index([clientId])
  @@index([companyId])
  @@index([contactId])
  @@index([opportunityId])
  @@index([deletedAt])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  type        String   @default("product")
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0)
  discount    Decimal  @default(0)
  subtotal    Decimal  @default(0)

  @@index([quoteId])
  @@index([productId])
}

model Commission {
  id              String           @id @default(cuid())
  quoteId         String?
  quote           Quote?           @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  sellerProfileId String
  sellerProfile   StaffProfile     @relation("CommissionSellerProfile", fields: [sellerProfileId], references: [id], onDelete: Cascade)
  type            CommissionType   @default(SALE_PERCENTAGE)
  baseAmount      Decimal          @default(0)
  rate            Decimal          @default(0)
  amount          Decimal          @default(0)
  status          CommissionStatus @default(PENDING)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([sellerProfileId, status])
  @@index([quoteId])
}

model Opportunity {
  id              String            @id @default(cuid())
  code            String            @unique
  title           String
  companyId       String
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  leadId          String?           @unique
  lead            Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  sellerProfileId String?
  sellerProfile   StaffProfile?     @relation("OpportunitySellerProfile", fields: [sellerProfileId], references: [id], onDelete: SetNull)
  status          OpportunityStatus @default(OPEN)
  source          String?
  interest        String?
  estimatedValue  Decimal?
  probability     Int               @default(25)
  nextStep        String?
  nextFollowUpAt  DateTime?
  notes           String?
  quotes          Quote[]
  sales           Sale[]
  activities      ActivityLog[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  projects        Project[]

  @@index([companyId])
  @@index([contactId])
  @@index([sellerProfileId])
  @@index([status, createdAt])
  @@index([deletedAt])
}

model Sale {
  id               String        @id @default(cuid())
  number           String        @unique
  quoteId          String?       @unique
  quote            Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  opportunityId    String?
  opportunity      Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  clientId         String?
  client           Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  companyId        String?
  company          Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId        String?
  contact          Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  sellerProfileId  String?
  sellerProfile    StaffProfile? @relation("SaleSellerProfile", fields: [sellerProfileId], references: [id], onDelete: SetNull)
  status           SaleStatus    @default(PENDING)
  currency         String        @default("USD")
  amount           Decimal       @default(0)
  commissionAmount Decimal       @default(0)
  paidAt           DateTime?
  projects         Project[]
  activities       ActivityLog[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  @@index([status, createdAt])
  @@index([companyId])
  @@index([clientId])
  @@index([sellerProfileId])
  @@index([deletedAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  message   String
  intent    String?
  context   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model ChatConversation {
  id                String        @id @default(cuid())
  customerName      String
  customerEmail     String?
  customerPhone     String?
  topic             String?
  status            ChatStatus    @default(WAITING)
  assignedToId      String?
  assignedTo        User?         @relation(fields: [assignedToId], references: [id])
  assignedProfileId String?
  assignedProfile   StaffProfile? @relation(fields: [assignedProfileId], references: [id], onDelete: SetNull)
  messages          ChatMessage[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([assignedToId])
  @@index([assignedProfileId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String
  body           String
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

model InternalChatChannel {
  id          String                @id @default(cuid())
  name        String
  slug        String                @unique
  description String?
  messages    InternalChatMessage[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model InternalChatMessage {
  id        String              @id @default(cuid())
  channelId String
  channel   InternalChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  body      String
  files     String[]
  leadId    String?
  projectId String?
  ticketId  String?
  createdAt DateTime            @default(now())

  @@index([channelId, createdAt])
  @@index([userId])
}

model BotConversation {
  id              String       @id @default(cuid())
  customerName    String?
  customerEmail   String?
  status          String       @default("bot")
  provider        BotProvider  @default(LOCAL)
  escalatedChatId String?
  messages        BotMessage[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status, createdAt])
}

model BotMessage {
  id             String          @id @default(cuid())
  conversationId String
  conversation   BotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String
  body           String
  source         String?
  confidence     Decimal?
  createdAt      DateTime        @default(now())

  @@index([conversationId, createdAt])
}

model BotUnansweredQuestion {
  id        String            @id @default(cuid())
  question  String            @unique
  answer    String?
  category  String?
  source    String?
  frequency Int               @default(1)
  status    BotQuestionStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status, frequency])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(SYSTEM)
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
  @@index([type, createdAt])
}

model StaffProfile {
  id              String                @id @default(cuid())
  userId          String?               @unique
  user            User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  displayName     String
  email           String?               @unique
  phone           String?
  roleTitle       String
  department      StaffDepartment       @default(SALES)
  avatar          String?
  availability    TechnicalAvailability @default(AVAILABLE)
  workZone        String?
  experience      String?
  certifications  String[]
  documents       String[]
  commissionType  CommissionType        @default(SALE_PERCENTAGE)
  commissionRate  Decimal               @default(5)
  fixedCommission Decimal               @default(0)
  monthlyGoal     Decimal               @default(0)
  territory       String?
  internalNotes   String?
  specialties     String[]
  tools           Json
  active          Boolean               @default(true)
  assignedChats   ChatConversation[]
  assignedLeads   Lead[]                @relation("LeadAssignedProfile")
  opportunities   Opportunity[]         @relation("OpportunitySellerProfile")
  quotes          Quote[]               @relation("QuoteSellerProfile")
  sales           Sale[]                @relation("SaleSellerProfile")
  commissions     Commission[]          @relation("CommissionSellerProfile")
  projectMembers  ProjectMember[]
  tasks           Task[]                @relation("TaskAssigneeProfile")
  ticketAssignee  Ticket[]              @relation("TicketAssigneeProfile")
  progressEntries ProjectProgress[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([department, active])
}

model Project {
  id              String            @id @default(cuid())
  title           String
  slug            String            @unique
  clientId        String?
  client          Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  companyId       String?
  company         Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  opportunityId   String?
  opportunity     Opportunity?      @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  saleId          String?
  sale            Sale?             @relation(fields: [saleId], references: [id], onDelete: SetNull)
  clientName      String?
  location        String?
  category        String?
  servicesApplied String[]
  summary         String
  description     String
  challenge       String?
  solution        String?
  results         String?
  status          ProjectStatus     @default(PLANNING)
  isPublic        Boolean           @default(false)
  isFeatured      Boolean           @default(false)
  images          ProjectImage[]
  members         ProjectMember[]
  progress        ProjectProgress[]
  milestones      Milestone[]
  tasks           Task[]
  documents       Document[]
  activities      ActivityLog[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  @@index([status, isPublic])
  @@index([isFeatured])
  @@index([clientId])
  @@index([companyId])
  @@index([opportunityId])
  @@index([deletedAt])
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([projectId, position])
}

model ProjectMember {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  staffProfileId String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  role           ProjectRole  @default(SURVEYOR)
  createdAt      DateTime     @default(now())

  @@unique([projectId, staffProfileId, role])
  @@index([staffProfileId])
}

model ProjectProgress {
  id             String        @id @default(cuid())
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  staffProfileId String?
  staffProfile   StaffProfile? @relation(fields: [staffProfileId], references: [id], onDelete: SetNull)
  title          String
  body           String
  milestone      String?
  files          String[]
  createdAt      DateTime      @default(now())

  @@index([projectId, createdAt])
  @@index([staffProfileId])
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  tasks       Task[]
  documents   Document[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([projectId, status])
  @@index([dueDate])
  @@index([deletedAt])
}

model Task {
  id                String        @id @default(cuid())
  projectId         String
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId       String?
  milestone         Milestone?    @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  assignedProfileId String?
  assignedProfile   StaffProfile? @relation("TaskAssigneeProfile", fields: [assignedProfileId], references: [id], onDelete: SetNull)
  title             String
  description       String?
  status            TaskStatus    @default(TODO)
  dueDate           DateTime?
  completedAt       DateTime?
  documents         Document[]
  activities        ActivityLog[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  @@index([projectId, status])
  @@index([milestoneId])
  @@index([assignedProfileId])
  @@index([dueDate])
  @@index([deletedAt])
}

model Ticket {
  id                String          @id @default(cuid())
  code              String          @unique
  clientId          String?
  client            Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  companyId         String?
  companyRef        Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId         String?
  contact           Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedProfileId String?
  assignedProfile   StaffProfile?   @relation("TicketAssigneeProfile", fields: [assignedProfileId], references: [id], onDelete: SetNull)
  customerName      String
  customerEmail     String
  company           String?
  subject           String
  category          TicketCategory  @default(TECHNICAL_QUERY)
  priority          TicketPriority  @default(MEDIUM)
  status            TicketStatus    @default(OPEN)
  description       String
  attachments       String[]
  messages          TicketMessage[]
  documents         Document[]
  activities        ActivityLog[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  closedAt          DateTime?
  deletedAt         DateTime?

  @@index([status, createdAt])
  @@index([clientId])
  @@index([companyId])
  @@index([contactId])
  @@index([assignedProfileId])
  @@index([customerEmail])
  @@index([deletedAt])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  sender    String
  body      String
  files     String[]
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@index([authorId])
}

model ClientDocument {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  url       String
  type      String?
  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
}

model Document {
  id          String     @id @default(cuid())
  title       String
  url         String
  type        String?
  visibility  String     @default("internal")
  companyId   String?
  company     Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId   String?
  contact     Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId String?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  taskId      String?
  task        Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  ticketId    String?
  ticket      Ticket?    @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([companyId])
  @@index([projectId])
  @@index([ticketId])
  @@index([visibility])
  @@index([deletedAt])
}

model ActivityLog {
  id            String         @id @default(cuid())
  actorId       String?
  actor         User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action        ActivityAction
  entityType    String
  entityId      String
  title         String
  body          String?
  metadata      Json?
  companyId     String?
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId     String?
  contact       Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  leadId        String?
  lead          Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  opportunityId String?
  opportunity   Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  quoteId       String?
  quote         Quote?         @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  saleId        String?
  sale          Sale?          @relation(fields: [saleId], references: [id], onDelete: SetNull)
  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskId        String?
  task          Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  ticketId      String?
  ticket        Ticket?        @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([companyId, createdAt])
  @@index([leadId, createdAt])
  @@index([opportunityId, createdAt])
  @@index([quoteId, createdAt])
  @@index([saleId, createdAt])
  @@index([projectId, createdAt])
  @@index([ticketId, createdAt])
}
